{
  "manifest_version": 3,
  "name": "VideoNotes Pro",
  "version": "1.0.0",
  "description": "Take timestamped notes on any YouTube video. Click any note to jump back instantly.",
  "permissions": ["sidePanel", "storage", "activeTab", "scripting"],
  "host_permissions": ["*://*.youtube.com/*"],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ExtPay.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
